      "page": "/myrequest/[taskId]/applications",
      "regex": "^/myrequest/([^/]+?)/applications(?:/)?$",
      "routeKeys": {
        "nxtPtaskId": "nxtPtaskId"
      },
      "namedRegex": "^/myrequest/(?<nxtPtaskId>[^/]+?)/applications(?:/)?$"
    }
  ],
